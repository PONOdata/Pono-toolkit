<local:BaseWindow
    x:Class="LenovoLegionToolkit.WPF.Windows.Automation.AutomationPipelineTriggerConfigurationWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:LenovoLegionToolkit.WPF.Windows"
    xmlns:resources="clr-namespace:LenovoLegionToolkit.WPF.Resources"
    xmlns:utils="clr-namespace:LenovoLegionToolkit.WPF.Utils"
    xmlns:wpfui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="{x:Static resources:Resource.AutomationPipelineTriggerConfigurationWindow_Title}"
    Width="500"
    Height="600"
    MinWidth="500"
    MinHeight="600"
    FlowDirection="{x:Static utils:LocalizationHelper.Direction}"
    Initialized="AutomationPipelineTriggerConfigurationWindow_Initialized"
    ResizeMode="CanMinimize"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterOwner">

    <Grid>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <wpfui:TitleBar
                Grid.Row="0"
                CanMaximize="false"
                ShowMaximize="false"
                ShowMinimize="false"
                UseSnapLayout="false" />

            <Grid
                Grid.Row="0"
                Height="24"
                Margin="12,8,12,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    FontSize="12"
                    IsHitTestVisible="False"
                    Text="{x:Static resources:Resource.AutomationPipelineTriggerConfigurationWindow_Title}" />

            </Grid>

            <TabControl
                x:Name="_tabControl"
                Grid.Row="1"
                Margin="16" />

            <Grid Grid.Row="2" Margin="0,0,12,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel
                    x:Name="_logicSelection"
                    Grid.Column="0"
                    Margin="12,0,0,0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Visibility="Collapsed">
                    <TextBlock VerticalAlignment="Center" Text="{x:Static resources:Resource.MultipleTriggersAutomationPipelineTrigger_Logic_Title}" />
                    <ComboBox
                        x:Name="_logicComboBox"
                        MinWidth="120"
                        Margin="8,0,0,0"
                        SelectedIndex="0">
                        <ComboBoxItem Content="{x:Static resources:Resource.MultipleTriggersAutomationPipelineTrigger_Logic_And}" />
                        <ComboBoxItem Content="{x:Static resources:Resource.MultipleTriggersAutomationPipelineTrigger_Logic_Or}" />
                    </ComboBox>
                </StackPanel>

                <wpfui:Button
                    Grid.Column="1"
                    MinWidth="100"
                    Margin="8,0,0,0"
                    Appearance="Primary"
                    Click="SaveButton_Click"
                    Content="{x:Static resources:Resource.Save}" />

                <wpfui:Button
                    Grid.Column="2"
                    MinWidth="100"
                    Margin="8,0,0,0"
                    Click="CancelButton_Click"
                    Content="{x:Static resources:Resource.Cancel}" />

            </Grid>
        </Grid>
    </Grid>
</local:BaseWindow>
