<wpfui:UiWindow
    x:Class="LenovoLegionToolkit.WPF.Windows.Utils.UpstreamShoutoutWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:utils="clr-namespace:LenovoLegionToolkit.WPF.Utils"
    xmlns:wpfui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Pono Toolkit"
    MinWidth="520"
    MinHeight="320"
    MaxWidth="520"
    MaxHeight="360"
    ExtendsContentIntoTitleBar="True"
    FlowDirection="{x:Static utils:LocalizationHelper.Direction}"
    ResizeMode="NoResize"
    Topmost="True"
    WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <wpfui:TitleBar
            Title="Pono Toolkit"
            Grid.Row="0"
            CanMaximize="false"
            ShowMaximize="false"
            ShowMinimize="false"
            UseSnapLayout="false" />

        <Grid Grid.Row="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <wpfui:SymbolIcon
                Grid.Row="0"
                Grid.RowSpan="2"
                Grid.Column="0"
                Margin="0,0,16,0"
                VerticalAlignment="Top"
                FontSize="48"
                Symbol="Heart24" />

            <TextBlock
                Grid.Row="0"
                Grid.Column="1"
                Margin="0,0,0,12"
                Focusable="True"
                FontSize="16"
                FontWeight="Medium"
                Text="Standing on shoulders" />

            <TextBlock
                Grid.Row="1"
                Grid.Column="1"
                Focusable="True"
                Text="Pono Toolkit is a fork of Lenovo Legion Toolkit. The foundation under everything in this build is years of work by Bartosz Cichecki (original author) and Kaguya (current upstream developer). If this software is useful to you, the most direct way to support it is to support upstream."
                TextWrapping="Wrap" />

            <wpfui:Hyperlink
                Grid.Row="2"
                Grid.Column="1"
                Margin="0,16,0,0"
                Click="DonateUpstream_Click"
                Content="Donate to upstream LLT (PayPal)"
                Icon="Heart24" />

            <Grid
                Grid.Row="3"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Margin="0,16,0,0"
                HorizontalAlignment="Right">

                <wpfui:Button
                    MinWidth="120"
                    Appearance="Primary"
                    Click="OK_Click"
                    Content="Got it" />
            </Grid>
        </Grid>
    </Grid>
</wpfui:UiWindow>
